          "key": {
            "description": "Custom field key (e.g. 'ID', 'Hebrew Birthday', 'Account Number').",
            "type": "string"
          },
          "value": {
            "default": "",
            "description": "Custom field value. May be omitted when using remove mode (only the key is needed).",
