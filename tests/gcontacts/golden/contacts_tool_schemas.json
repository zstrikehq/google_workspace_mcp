          "key"
        ],
        "type": "object"
      }
    },
    "additionalProperties": false,
    "properties": {
      "action": {
        "description": "The action to perform: \"create\", \"update\", or \"delete\".",
        "enum": [
          "create",
          "update",
          "delete"
        ],
        "type": "string"
      },
      "address": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Street address (for create/update)."
      },
      "birthday": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Birthday as 'YYYY-MM-DD', 'MM-DD' (no year), or 'clear'/'' to remove."
      },
      "contact_id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "The contact ID. Required for \"update\" and \"delete\" actions."
      },
      "email": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "[DEPRECATED] Email address. Use emails=[{\"address\":..., \"type\":\"other\"}]."
      },
      "emails": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/EmailInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of email dicts {address, type?}."
      },
      "emails_mode": {
        "default": "merge",
        "description": "How to update emails on \"update\": \"merge\" (default), \"replace\", or \"remove\".",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "family_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Last name (for create/update)."
      },
      "given_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "First name (for create/update)."
      },
      "job_title": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "[DEPRECATED] Job title. Use organizations=[{\"title\":...}]."
      },
      "nicknames": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/NicknameInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of nickname dicts {value, type?}.\nUseful for bilingual contacts (e.g. Hebrew/English alternative forms). Android dialer\nand WhatsApp search both index nicknames, enabling cross-script lookup.\nSupported types: default, alternate_name, maiden_name, initials, other, etc."
      },
      "nicknames_mode": {
        "default": "merge",
        "description": "How to update nicknames on \"update\": \"merge\" (default), \"replace\", or \"remove\".",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "notes": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Additional notes (for create/update)."
      },
      "organization": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "[DEPRECATED] Company name. Use organizations=[{\"name\":...}]."
      },
      "organizations": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/OrganizationInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of org dicts {name?, title?, department?, jobDescription?, type?}."
      },
      "organizations_mode": {
        "default": "merge",
        "description": "How to update orgs on \"update\": \"merge\" (default), \"replace\", or \"remove\".",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "phone": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "[DEPRECATED] Single phone number. Use phones=[{\"number\":..., \"type\":\"mobile\"}]."
      },
      "phones": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/PhoneInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of phone dicts {number, type?}.\nSupported types: mobile, work, home, main, workMobile, internal, other, etc.\nUse type=\"internal\" for internal PBX/ATS short numbers (e.g. 250, 301) \u2014 stored\nas a standalone number without + prefix, displayed as \"Internal: 250\"."
      },
      "phones_mode": {
        "default": "merge",
        "description": "How to update phones on \"update\": \"merge\" (default), \"replace\", or \"remove\".\nmerge = read-modify-write with dedup by canonicalForm/normalized value.\nreplace = overwrite all phones with provided list.\nremove = delete phones matching provided numbers.",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "relations": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/RelationInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of relation dicts {person, type?}.\nSupported types: spouse, child, parent, friend, manager, assistant, etc."
      },
      "relations_mode": {
        "default": "merge",
        "description": "How to update relations on \"update\": \"merge\" (default), \"replace\", or \"remove\".",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "urls": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/UrlInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of URL dicts {value, type?}.\nSupported types: homepage, blog, profile, work, ftp, reservations, other, etc."
      },
      "urls_mode": {
        "default": "merge",
        "description": "How to update urls on \"update\": \"merge\" (default), \"replace\", or \"remove\".\nmerge dedups by normalized URL (lowercased, trailing slash stripped).",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "user_defined": {
        "anyOf": [
          {
            "items": {
              "$ref": "#/$defs/UserDefinedInput"
            },
            "type": "array"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "List of custom field dicts {key, value}.\nUseful for structured data like account numbers, IDs, or custom dates."
      },
      "user_defined_mode": {
        "default": "merge",
        "description": "How to update custom fields on \"update\": \"merge\" (default), \"replace\", or \"remove\".\nmerge overrides value on matching key; new keys appended.",
        "enum": [
          "merge",
          "replace",
          "remove"
        ],
        "type": "string"
      },
      "user_google_email": {
        "description": "The user's Google email address. Required.",
        "type": "string"
      }
    },
    "required": [
      "user_google_email",
      "action"
    ],
    "type": "object"
  },
